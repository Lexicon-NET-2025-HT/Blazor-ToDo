@inherits LayoutComponentBase

<div class="min-vh-100 d-flex flex-column bg-body-tertiary">

    <header class="sticky-top">
        <NavBar NavTitle="Lexicon ToDo">
            <Right>
              <button class="btn btn-outline-secondary btn-sm" type="button">Inserted with fragments</button>
            </Right>
        </NavBar>
    </header>

    <main class="flex-grow-1">
        <div class="container py-4">
            @Body
        </div>
    </main>

    <footer class="border-top bg-body">
        <div class="container py-3 small text-secondary">
            Demo • Blazor
        </div>
    </footer>

</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
