@page "/"

<PageTitle>ToDo</PageTitle>

<Input OnAdd ="AddTodo"/>

<Items  ToDoItems="_toDoItems" OnDelete="DeleteTodo" OnToggle="ToggleToDo"/>


@code {

    private List<ToDoItem> _toDoItems = default!;

    [Inject]
    public ToDoState State { get; set; } = null!;


    protected override void OnInitialized()
    {
        _toDoItems =
                 [
              new(){Text = "Buy bananas", Completed = true, Created = DateTime.Now.AddDays(-2)},
              new(){Text = "Walk the dog"},
              new(){Text = "Coffe",  Created = DateTime.Now.AddDays(-1).AddHours(5)},

                 ];
           
                 UpdateCount();
    }

    private void AddTodo(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return;

        _toDoItems.Add(new ToDoItem { Text = text.Trim() });

        UpdateCount();
    }

    private void DeleteTodo(Guid id)
    {
        var item = _toDoItems.FirstOrDefault(i => i.Id == id);

        if (item == null) return;

        _toDoItems.Remove(item);

        UpdateCount();
    }

    private void ToggleToDo(Guid id)
    {
        var item = _toDoItems.FirstOrDefault(i => i.Id == id);

        if (item == null) return;

        item.Completed = !item.Completed;
    }

    private void UpdateCount() => State.SetCount(_toDoItems.Count);

}